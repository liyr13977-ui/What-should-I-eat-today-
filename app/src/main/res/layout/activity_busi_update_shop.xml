<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activity.BusiUpdateShopActivity"
    android:orientation="vertical"
    android:fitsSystemWindows="true">


    <androidx.appcompat.widget.Toolbar
        android:id="@+id/tb_UpdateShop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/blue"
        app:navigationIcon="@drawable/back"
        app:title="店铺信息修改"
        app:titleTextColor="@color/white" />


    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginLeft="30dp"
            android:layout_marginRight="30dp"
            android:gravity="center_vertical|center_horizontal">

            <ImageView
                android:id="@+id/iv_shopPicture_Update"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/upimg"
                android:layout_marginTop="45dp"
                android:background="@drawable/img_round"
                android:scaleType="centerCrop"
                android:clipToOutline="true"
                tools:targetApi="s" />


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="店铺头像"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="#000000"
                android:gravity="center_horizontal|center_vertical"/>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">


                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="店铺名称"
                    android:textSize="14sp"
                    android:layout_marginTop="20dp"/>

                <EditText
                    android:id="@+id/et_shopName_Update"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:background="@drawable/rounded_edittext"
                    android:hint="请输入店铺名称" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="联系电话"
                    android:textSize="14sp"
                    android:layout_marginTop="10dp"/>

                <EditText
                    android:id="@+id/et_busi_updateShop_phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:background="@drawable/rounded_edittext"
                    android:hint="请输入联系电话" />


                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="配送费"
                    android:textSize="14sp"
                    android:layout_marginTop="10dp"/>

                <EditText
                    android:id="@+id/et_busi_updateShop_fee"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:background="@drawable/rounded_edittext"
                    android:hint="请输入配送费" />


                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="店铺介绍"
                    android:textSize="14sp"
                    android:layout_marginTop="10dp"/>



                <EditText
                    android:id="@+id/et_shopDescribe_Update"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="请输入店铺介绍"
                    android:inputType="textMultiLine"
                    android:minLines="5"
                    android:maxLines="5"
                    android:textSize="20sp"
                    android:gravity="top"
                    android:scrollbars="vertical"
                    android:background="@drawable/rounded_edittext" />




            </LinearLayout>


            <Button
                android:id="@+id/btn_UpdateShop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@color/blue"
                android:foreground="?android:attr/selectableItemBackground"
                android:text="确认修改"
                android:textColor="@color/white" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>