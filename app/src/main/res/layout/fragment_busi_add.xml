<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".fragment.BusiAddFragment"
    android:orientation="vertical"
    android:fitsSystemWindows="true">


    <androidx.appcompat.widget.Toolbar
        android:id="@+id/tb_Addfood"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/blue"
        app:navigationIcon="@drawable/back"
        app:title="商品添加"
        app:titleTextColor="@color/white" />


    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginLeft="30dp"
            android:layout_marginRight="30dp"
            android:gravity="center_vertical|center_horizontal">

            <ImageView
                android:id="@+id/iv_foodPicture_add"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:src="@drawable/upimg"
                android:layout_marginTop="45dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/shop_picture"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="#000000"
                android:gravity="center_horizontal|center_vertical"/>


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="商品名称"
                android:textSize="14sp"
                android:layout_marginTop="20dp"/>


            <EditText
                android:id="@+id/et_foodName_add"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:background="@drawable/rounded_edittext"
                android:hint="请输入商品名称" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="商品价格"
                android:textSize="14sp"
                android:layout_marginTop="10dp"/>

            <EditText
                android:id="@+id/et_foodPrice_add"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:background="@drawable/rounded_edittext"
                android:hint="请输入商品价格" />


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="商品数量"
                android:textSize="14sp"
                android:layout_marginTop="10dp"/>

            <EditText
                android:id="@+id/et_foodNum_add"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:background="@drawable/rounded_edittext"
                android:hint="商品数量" />


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="商品介绍"
                android:textSize="14sp"
                android:layout_marginTop="10dp"/>


            <EditText
                android:id="@+id/et_foodDescribe_add"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="请输入商品介绍"
                android:inputType="textMultiLine"
                android:minLines="5"
                android:maxLines="5"
                android:gravity="top"
                android:textSize="20sp"
                android:background="@drawable/rounded_edittext"
                android:scrollbars="vertical" />


            <Button
                android:id="@+id/btn_addFood"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="70dp"
                android:background="@color/blue"
                android:foreground="?android:attr/selectableItemBackground"
                android:text="@string/add"
                android:textColor="@color/white" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>